<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jigsaw24.launchrights.helper</string>

    <key>Program</key>
    <string>/usr/local/libexec/launchrightsd</string>

    <!-- launchd registers this Mach service; the daemon claims it via NSXPCListener. -->
    <key>MachServices</key>
    <dict>
        <key>com.jigsaw24.launchrights.helper</key>
        <true/>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Tighten this to your agent's signing requirement before any real use.
         Leave unset only for the earliest local prototyping. -->
    <!--
    <key>EnvironmentVariables</key>
    <dict>
        <key>LAUNCHRIGHTS_AGENT_REQ</key>
        <string>anchor apple generic and certificate leaf[subject.OU] = "YOURTEAMID"</string>
    </dict>
    -->

    <key>StandardOutPath</key>
    <string>/var/log/launchrightsd.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/launchrightsd.log</string>
</dict>
</plist>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jigsaw24.launchrights.es</string>

    <!-- Points at the executable INSIDE the signed bundle, so it picks up the
         embedded provisioning profile that authorizes the ES entitlement. -->
    <key>Program</key>
    <string>/Library/Application Support/LaunchRights/LaunchRightsES.app/Contents/MacOS/launchrightsd-es</string>

    <key>MachServices</key>
    <dict>
        <key>com.jigsaw24.launchrights.helper</key>
        <true/>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/var/log/launchrightsd-es.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/launchrightsd-es.log</string>
</dict>
</plist>

# Copy to .env.local and fill in. Vite exposes VITE_* vars to the client.

# The beta-signup API endpoint (the `ApiUrl` output from the SAM stack in ../api).
# Leave unset to fall back to a pre-filled mailto instead of a live POST.
VITE_FORM_ENDPOINT=

# The shared API key sent as the "x-api-key" header. Must match the ApiKey
# parameter the API was deployed with. Note: anything in a VITE_* var ships in
# the client bundle, so this deters casual abuse — it is not a true secret.
VITE_API_KEY=

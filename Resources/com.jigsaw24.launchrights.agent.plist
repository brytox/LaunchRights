<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jigsaw24.launchrights.agent</string>

    <key>Program</key>
    <string>/usr/local/bin/launchrights-agent</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/launchrights-agent.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/launchrights-agent.log</string>
</dict>
</plist>
